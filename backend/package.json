{
  "name": "timelines-backend",
  "version": "1.0.0",
  "description": "GraphQL server for event timelines",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "dotenv -e ../.env -- nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@apollo/server": "^4.9.3",
    "@graphql-tools/schema": "^10.0.25",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-subscriptions": "^3.0.0",
    "graphql-type-json": "^0.3.2",
    "graphql-ws": "^6.0.6",
    "mongoose": "^7.5.3",
    "typescript": "^5.2.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/node": "^20.8.2",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^10.0.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.1"
  }
